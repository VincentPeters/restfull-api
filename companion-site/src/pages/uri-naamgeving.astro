</BaseLayout>

<style>
  .rule-section {
    opacity: 0;
    transform: translateY(16px);
    animation: revealSection 0.6s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }
  .rule-section:nth-child(4) { animation-delay: 0.05s; }
  .rule-section:nth-child(5) { animation-delay: 0.1s; }
  .rule-section:nth-child(6) { animation-delay: 0.15s; }
  .rule-section:nth-child(7) { animation-delay: 0.2s; }
  .rule-section:nth-child(8) { animation-delay: 0.25s; }
  .rule-section:nth-child(9) { animation-delay: 0.3s; }
  .rule-section:nth-child(10) { animation-delay: 0.35s; }
  .rule-section:nth-child(11) { animation-delay: 0.4s; }

  @keyframes revealSection {
