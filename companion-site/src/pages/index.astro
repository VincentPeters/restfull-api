---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const chapters = [
  {
    label: 'Referentie',
    exercises: [
      {
        title: 'Naslagwerk',
        description: 'HTTP-methoden, statuscodes, URI-regels en REST-principes op één plek.',
        href: `${base}/naslagwerk`,
        accent: 'var(--color-accent-sage)',
        span: 'large',
      },
    ],
  },
  {
    label: 'Hoofdstuk 1 — REST Principes',
    exercises: [
      {
        title: 'REST Quiz',
        description: 'Test je kennis van de vijf REST-principes met scenario-vragen.',
        href: `${base}/oefeningen/rest-quiz`,
        accent: 'var(--color-accent-sage)',
        span: 'small',
      },
      {
        title: 'Architectuur Builder',
        description: 'Sleep de lagen van een REST-architectuur in de juiste volgorde.',
        href: `${base}/oefeningen/architectuur`,
        accent: 'var(--color-accent-rust)',
        span: 'small',
      },
    ],
  },
  {
    label: 'Hoofdstuk 2 — URI Naamgeving',
    exercises: [
      {
        title: 'URI Spotter',
        description: 'Herken de correcte URI uit twee opties.',
        href: `${base}/oefeningen/uri-spotter`,
        accent: 'var(--color-accent-ochre)',
        span: 'small',
      },
      {
        title: 'URI Builder',
        description: 'Bouw zelf de juiste RESTful URI voor elk scenario.',
        href: `${base}/oefeningen/uri-builder`,
        accent: 'var(--color-accent-rust)',
        span: 'small',
      },
    ],
  },
  {
    label: 'Hoofdstuk 3 — API Clients',
    exercises: [
      {
        title: 'JSON Explorer',
        description: 'Verken live API-responses van de Gaming API en beantwoord uitdagingen.',
        href: `${base}/oefeningen/json-explorer`,
        accent: 'var(--color-accent-ochre)',
        span: 'large',
      },
    ],
  },
];
---

<BaseLayout title="Home">
  <!-- Hero -->
  <header class="pt-8 pb-14">
    <h1 class="mb-4">
      Leer REST APIs<br />
      <em class="font-light" style="font-variation-settings: 'opsz' 144;">begrijpen.</em>
    </h1>
    <p class="text-[var(--color-text-secondary)] max-w-xl text-lg leading-relaxed">
      Interactief compendium bij de RESTful API cursus. Oefen met URI's,
      HTTP-methoden, JSON-responses en architectuurprincipes — allemaal
      gekoppeld aan de
      <a href="https://kdg-gaming-api.me-945.workers.dev/docs" target="_blank" rel="noopener" class="underline underline-offset-2 decoration-[var(--color-border)] hover:decoration-[var(--color-accent-rust)]">
        KdG Gaming API</a>.
    </p>
  </header>

  <!-- Exercise Grid grouped by chapter -->
  {chapters.map((chapter) => (
    <section class="mb-10">
      <p class="text-xs font-medium tracking-wide uppercase text-[var(--color-text-secondary)] mb-3 pl-1">
        {chapter.label}
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        {chapter.exercises.map((ex) => (
          <a
            href={ex.href}
            class:list={[
              'group block p-7 rounded-lg transition-all duration-300',
              'bg-[var(--color-bg-secondary)] hover:bg-[var(--color-bg-primary)]',
              'border border-transparent hover:border-[var(--color-border)]',
              'hover:shadow-[0_2px_20px_rgba(0,0,0,0.04)]',
              ex.span === 'large' && 'md:col-span-2',
            ]}
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <div class="flex items-center gap-3 mb-2">
                  <span
                    class="w-2 h-2 rounded-full shrink-0"
                    style={`background-color: ${ex.accent};`}
                  />
                  <h3 class="text-lg font-medium" style="font-family: var(--font-display); font-variation-settings: 'opsz' 36;">
                    {ex.title}
                  </h3>
                </div>
                <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed pl-5">
                  {ex.description}
                </p>
              </div>
              <span class="text-[var(--color-text-secondary)] group-hover:text-[var(--color-accent-rust)] transition-colors duration-300 text-lg mt-1 shrink-0">
                →
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>
  ))}
</BaseLayout>
