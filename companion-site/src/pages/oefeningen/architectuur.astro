---
import BaseLayout from '../../layouts/BaseLayout.astro';
import data from '../../data/architecture-layers.json';
---

<BaseLayout title="Architectuur" breadcrumbs={[{ label: "Oefeningen", href: "/" }, { label: "Architectuur" }]}>
  <header class="mb-10">
    <h1 class="mb-3">Architectuur Builder</h1>
    <p class="text-[var(--color-text-secondary)] max-w-xl">
      Sleep de lagen van een REST API-architectuur in de juiste volgorde. Client en Database staan al vast.
    </p>
  </header>

  <div id="arch-game" data-layers={JSON.stringify(data.layers)}>
    <div class="grid md:grid-cols-2 gap-10">
      <!-- Drop Zone -->
      <div>
        <p class="text-sm text-[var(--color-text-secondary)] mb-4">Plaatsingsvolgorde (boven → onder)</p>
        <div id="drop-zone" class="space-y-3">
          <!-- Slot 0: Client (fixed) -->
          <div class="fixed-layer rounded-lg h-16 flex items-center justify-center" data-slot="0" data-layer-id="client">
            <div class="text-center">
              <p class="text-sm font-medium">Client</p>
              <p class="text-xs text-[var(--color-text-secondary)]">Browser, App of Node-RED</p>
            </div>
          </div>

          <!-- Slots 1-4: Draggable targets -->
          {[1, 2, 3, 4].map(i => (
            <div
              class="drop-slot border-2 border-dashed border-[var(--color-border)] rounded-lg h-16 flex items-center justify-center text-sm text-[var(--color-text-secondary)] transition-all duration-200"
              data-slot={i}
            >
              <span class="slot-label opacity-40">?</span>
            </div>
          ))}

          <!-- Slot 5: Database (fixed) -->
          <div class="fixed-layer rounded-lg h-16 flex items-center justify-center" data-slot="5" data-layer-id="database">
            <div class="text-center">
              <p class="text-sm font-medium">Database</p>
              <p class="text-xs text-[var(--color-text-secondary)]">Data Opslag</p>
            </div>
          </div>
        </div>

        <div class="flex gap-3 mt-6">
          <button id="check-btn" class="px-5 py-2.5 bg-[var(--color-bg-code)] text-[var(--color-bg-primary)] rounded-lg text-sm font-medium hover:opacity-90 transition-opacity cursor-pointer">
            Controleer
          </button>
          <button id="reset-btn" class="px-5 py-2.5 border border-[var(--color-border)] rounded-lg text-sm text-[var(--color-text-secondary)] hover:border-[var(--color-accent-rust)] hover:text-[var(--color-accent-rust)] transition-colors cursor-pointer">
            Reset
          </button>
        </div>

        <!-- Feedback -->
        <div id="feedback" class="hidden mt-6 py-4">
          <p id="feedback-result" class="font-medium text-sm"></p>
          <p id="feedback-detail" class="text-sm text-[var(--color-text-secondary)] mt-1"></p>
        </div>
      </div>

      <!-- Source Cards -->
      <div>
        <p class="text-sm text-[var(--color-text-secondary)] mb-4">Beschikbare lagen</p>
        <div id="source" class="space-y-3"></div>
      </div>
    </div>

    <!-- Explanation Panel (shown after correct answer) -->
    <div id="explanation-panel" class="hidden mt-12">
      <h2 class="mb-6">Hoe de lagen samenwerken</h2>
      <div class="space-y-0">
        {data.layers.map((layer, i) => (
          <div class="flex gap-4 items-start">
            <div class="flex flex-col items-center">
              <span class="w-8 h-8 flex items-center justify-center rounded-full bg-[var(--color-bg-code)] text-[var(--color-accent-ochre)] text-xs shrink-0" style="font-family: var(--font-code);">{i + 1}</span>
              {i < data.layers.length - 1 && (
                <div class="w-px h-8 bg-[var(--color-accent-sage)] opacity-40"></div>
              )}
            </div>
            <div class="pb-4">
              <p class="font-medium text-sm" style="font-family: var(--font-display);">
                {layer.label}
                <span class="text-[var(--color-text-secondary)] font-normal"> – {layer.subtitle}</span>
              </p>
              <p class="text-sm text-[var(--color-text-secondary)]">{layer.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .fixed-layer {
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    opacity: 0.6;
  }
  .layer-card {
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-bg-primary);
    cursor: grab;
    transition: all 0.2s cubic-bezier(0.25, 1, 0.5, 1);
    user-select: none;
  }
  .layer-card:hover {
    border-color: var(--color-accent-ochre);
    box-shadow: 0 2px 8px rgba(0,0,0,0.06);
  }
  .layer-card:active {
    cursor: grabbing;
  }
  .layer-card.dragging {
    opacity: 0.4;
    cursor: grabbing;
  }
  .drop-slot.over {
    border-color: var(--color-accent-ochre);
    background: color-mix(in oklch, var(--color-accent-ochre) 6%, transparent);
    transform: scale(1.02);
  }
  .drop-slot.filled {
    border-style: solid;
    border-color: var(--color-border);
    background: var(--color-bg-secondary);
    cursor: grab;
  }
  .drop-slot.filled:hover {
    border-color: var(--color-accent-ochre);
  }
  .drop-slot.correct {
    border-color: var(--color-accent-sage);
    background: color-mix(in oklch, var(--color-accent-sage) 8%, transparent);
  }
  .drop-slot.incorrect {
    border-color: var(--color-accent-rust);
    background: color-mix(in oklch, var(--color-accent-rust) 8%, transparent);
  }
</style>

<script>
  const gameEl = document.getElementById('arch-game')!;
  const allLayers: any[] = JSON.parse(gameEl.dataset.layers || '[]');

  // Only the 4 middle layers are draggable
  const draggableLayers = allLayers.filter(l => l.id !== 'client' && l.id !== 'database');

  const $source = document.getElementById('source')!;
  const $dropZone = document.getElementById('drop-zone')!;
  const $feedback = document.getElementById('feedback')!;
  const $feedbackResult = document.getElementById('feedback-result')!;
  const $feedbackDetail = document.getElementById('feedback-detail')!;
  const $explanation = document.getElementById('explanation-panel')!;

  // Slots 1-4 hold the draggable layers
  let placements: (string | null)[] = [null, null, null, null];
  let dragSource: { type: 'source' | 'slot'; id: string; slotIdx?: number } | null = null;

  function shuffle<T>(arr: T[]): T[] {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function getSlots(): HTMLElement[] {
    return Array.from($dropZone.querySelectorAll('.drop-slot')) as HTMLElement[];
  }

  function renderSource() {
    const placedIds = placements.filter(Boolean);
    $source.innerHTML = '';

    const available = shuffle(draggableLayers.filter(l => !placedIds.includes(l.id)));
    available.forEach(layer => {
      const card = createCard(layer);
      $source.appendChild(card);
    });
  }

  function createCard(layer: any): HTMLElement {
    const card = document.createElement('div');
    card.className = 'layer-card';
    card.draggable = true;
    card.dataset.layerId = layer.id;
    card.innerHTML = `
      <p class="text-sm font-medium">${layer.label}</p>
      <p class="text-xs text-[var(--color-text-secondary)]">${layer.subtitle}</p>
      <p class="text-xs text-[var(--color-text-secondary)] mt-1 opacity-70">${layer.description}</p>
    `;

    card.addEventListener('dragstart', (e) => {
      card.classList.add('dragging');
      dragSource = { type: 'source', id: layer.id };
      e.dataTransfer!.setData('text/plain', layer.id);
      e.dataTransfer!.effectAllowed = 'move';
    });
    card.addEventListener('dragend', () => card.classList.remove('dragging'));

    return card;
  }

  function renderSlot(slotEl: HTMLElement, slotIdx: number) {
    const layerId = placements[slotIdx];
    if (layerId) {
      const layer = allLayers.find(l => l.id === layerId);
      slotEl.classList.add('filled');
      slotEl.classList.remove('correct', 'incorrect');
      slotEl.draggable = true;
      slotEl.innerHTML = `
        <div class="text-center">
          <p class="text-sm font-medium">${layer.label}</p>
          <p class="text-xs text-[var(--color-text-secondary)]">${layer.subtitle}</p>
        </div>
      `;
    } else {
      slotEl.classList.remove('filled', 'correct', 'incorrect');
      slotEl.draggable = false;
      slotEl.innerHTML = `<span class="slot-label opacity-40">?</span>`;
    }
  }

  function init() {
    placements = [null, null, null, null];
    $explanation.classList.add('hidden');
    $feedback.classList.add('hidden');

    getSlots().forEach((s, i) => renderSlot(s, i));
    renderSource();
  }

  // Setup slot events
  getSlots().forEach(s => {
    const slotIdx = parseInt(s.dataset.slot || '1') - 1; // slots are 1-4, array is 0-3

    // Drag from filled slot
    s.addEventListener('dragstart', (e) => {
      if (!s.classList.contains('filled')) { e.preventDefault(); return; }
      const layerId = placements[slotIdx];
      if (!layerId) { e.preventDefault(); return; }
      dragSource = { type: 'slot', id: layerId, slotIdx };
      e.dataTransfer!.setData('text/plain', layerId);
      e.dataTransfer!.effectAllowed = 'move';
      s.classList.add('dragging');
    });
    s.addEventListener('dragend', () => s.classList.remove('dragging'));

    s.addEventListener('dragover', (e) => {
      e.preventDefault();
      e.dataTransfer!.dropEffect = 'move';
      s.classList.add('over');
    });
    s.addEventListener('dragleave', () => s.classList.remove('over'));

    s.addEventListener('drop', (e) => {
      e.preventDefault();
      s.classList.remove('over');
      const layerId = e.dataTransfer!.getData('text/plain');
      if (!layerId || !dragSource) return;

      if (dragSource.type === 'slot' && dragSource.slotIdx !== undefined) {
        // Swap between slots
        const fromIdx = dragSource.slotIdx;
        const existingInTarget = placements[slotIdx];
        placements[slotIdx] = layerId;
        placements[fromIdx] = existingInTarget;

        const fromSlot = getSlots()[fromIdx];
        renderSlot(fromSlot, fromIdx);
        renderSlot(s, slotIdx);
      } else {
        // From source to slot
        const existingInTarget = placements[slotIdx];
        placements[slotIdx] = layerId;
        renderSlot(s, slotIdx);

        // If slot was already filled, the old one goes back to source
        // renderSource handles this automatically
      }

      renderSource();
      dragSource = null;
    });

    // Click filled slot to return to source
    s.addEventListener('click', () => {
      if (!s.classList.contains('filled')) return;
      placements[slotIdx] = null;
      renderSlot(s, slotIdx);
      renderSource();
    });
  });

  document.getElementById('check-btn')!.addEventListener('click', () => {
    if (placements.some(p => p === null)) {
      $feedbackResult.textContent = 'Plaats eerst alle lagen!';
      $feedbackResult.style.color = 'var(--color-accent-ochre)';
      $feedbackDetail.textContent = '';
      $feedback.className = 'mt-6 py-4';
      $feedback.classList.remove('hidden');
      return;
    }

    let correct = 0;
    const slots = getSlots();
    slots.forEach((s, i) => {
      const placedId = placements[i];
      // Slots 1-4 map to order 2-5
      const expected = allLayers.find(l => l.order === i + 2);
      s.classList.remove('correct', 'incorrect');
      if (placedId === expected.id) {
        s.classList.add('correct');
        correct++;
      } else {
        s.classList.add('incorrect');
      }
    });

    if (correct === 4) {
      $feedbackResult.textContent = 'Perfect! Alle lagen staan in de juiste volgorde.';
      $feedbackResult.style.color = 'var(--color-accent-sage)';
      $feedback.className = 'feedback-correct mt-6 py-4';
      $feedbackDetail.textContent = 'Dit is hoe het Layered System principe werkt: elke laag heeft zijn eigen verantwoordelijkheid.';
      $explanation.classList.remove('hidden');
    } else {
      $feedbackResult.textContent = `${correct} van 4 lagen correct.`;
      $feedbackResult.style.color = 'var(--color-accent-rust)';
      $feedback.className = 'feedback-incorrect mt-6 py-4';
      $feedbackDetail.textContent = 'Groene lagen staan goed, rode niet. Denk na over de volgorde waarin een request verwerkt wordt.';
    }
    $feedback.classList.remove('hidden');
  });

  document.getElementById('reset-btn')!.addEventListener('click', init);

  init();
</script>
