        ].map(({ num, name, summary }) => (
          <a href={`#regel-${num}`} class="group block p-4 rounded-lg bg-[var(--color-bg-primary)] hover:bg-white transition-colors duration-200">
            <span class="block text-2xl font-light text-[var(--color-accent-ochre)] mb-2" style="font-family: var(--font-display); font-variation-settings: 'opsz' 144;">{num}</span>
            <span class="block text-sm font-medium mb-1" style="font-family: var(--font-display);">{name}</span>
            <span class="block text-xs text-[var(--color-text-secondary)] leading-relaxed">{summary}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Quick reference specimen -->
  <section class="mb-16">
    <h2 class="mb-6">Snelreferentie</h2>
    <div class="specimen rounded-xl p-6">
      <p class="text-[10px] uppercase tracking-widest text-[#6B6560] mb-4" style="font-family: var(--font-code);">Voorbeeld: een volledige RESTful API</p>
      <div class="space-y-2 text-[13px]" style="font-family: var(--font-code);">
        <div><span class="text-[var(--color-accent-sage)]">GET</span>    <span class="text-[#F7F3EE]">/games</span>                          <span class="text-[#6B6560]">  alle games</span></div>
        <div><span class="text-[var(--color-accent-sage)]">GET</span>    <span class="text-[#F7F3EE]">/games</span><span class="text-[#A89F94]">?genre=rpg&sort=rating</span>   <span class="text-[#6B6560]">  gefilterd + gesorteerd</span></div>
        <div><span class="text-[var(--color-accent-sage)]">GET</span>    <span class="text-[#F7F3EE]">/games/</span><span class="text-[var(--color-accent-ochre)]">42</span>                       <span class="text-[#6B6560]">  één specifieke game</span></div>
        <div><span class="text-[var(--color-accent-ochre)]">POST</span>   <span class="text-[#F7F3EE]">/games</span>                          <span class="text-[#6B6560]">  nieuwe game aanmaken</span></div>
        <div><span class="text-[var(--color-accent-ochre)]">PUT</span>    <span class="text-[#F7F3EE]">/games/</span><span class="text-[var(--color-accent-ochre)]">42</span>                       <span class="text-[#6B6560]">  game volledig bijwerken</span></div>
        <div><span class="text-[var(--color-accent-rust)]">DELETE</span> <span class="text-[#F7F3EE]">/games/</span><span class="text-[var(--color-accent-ochre)]">42</span>                       <span class="text-[#6B6560]">  game verwijderen</span></div>
        <div class="pt-2 border-t border-[#3D3A36]"></div>
        <div><span class="text-[var(--color-accent-sage)]">GET</span>    <span class="text-[#F7F3EE]">/games/</span><span class="text-[var(--color-accent-ochre)]">42</span><span class="text-[#F7F3EE]">/reviews</span>              <span class="text-[#6B6560]">  reviews van game 42</span></div>
        <div><span class="text-[var(--color-accent-ochre)]">POST</span>   <span class="text-[#F7F3EE]">/games/</span><span class="text-[var(--color-accent-ochre)]">42</span><span class="text-[#F7F3EE]">/reviews</span>              <span class="text-[#6B6560]">  review toevoegen</span></div>
        <div><span class="text-[var(--color-accent-sage)]">GET</span>    <span class="text-[#F7F3EE]">/developers</span>                     <span class="text-[#6B6560]">  alle developers</span></div>
        <div><span class="text-[var(--color-accent-sage)]">GET</span>    <span class="text-[#F7F3EE]">/developers/</span><span class="text-[var(--color-accent-ochre)]">7</span><span class="text-[#F7F3EE]">/games</span>            <span class="text-[#6B6560]">  games van developer 7</span></div>
      </div>
    </div>
  </section>

  <!-- CTA to exercises -->
