---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout title="De 5 REST-principes" breadcrumbs={[{ label: "REST-principes" }]}>

  <header class="mb-16 pt-4">
    <p class="text-xs font-medium tracking-wide uppercase text-[var(--color-accent-rust)] mb-3" style="font-family: var(--font-code);">Hoofdstuk 1</p>
    <h1 class="mb-5">De 5 REST-principes</h1>
    <p class="text-[var(--color-text-secondary)] max-w-2xl text-lg leading-relaxed">
      REST staat voor <em>Representational State Transfer</em>, een set principes
      voor het ontwerpen van webapplicaties. RESTful web-API's werken met een
      client-server model. Begrijp deze vijf principes en je begrijpt het fundament
      van elke moderne API.
    </p>
  </header>

  <!-- Quick nav pills -->
  <nav class="mb-16 flex flex-wrap gap-2" aria-label="Principes">
    {['Uniform Interface', 'Client-Server', 'Stateless', 'Cacheable', 'Layered System'].map((name, i) => (
      <a
        href={`#principe-${i + 1}`}
        class="inline-flex items-center gap-2 px-4 py-2 text-sm rounded-full border border-[var(--color-border)] text-[var(--color-text-secondary)] hover:border-[var(--color-accent-rust)] hover:text-[var(--color-accent-rust)] transition-colors duration-200"
      >
        <span class="w-5 h-5 flex items-center justify-center rounded-full bg-[var(--color-bg-code)] text-[var(--color-accent-ochre)] text-[10px] font-medium" style="font-family: var(--font-code);">{i + 1}</span>
        {name}
      </a>
    ))}
  </nav>

  <!-- ═══════════════════════════════════════════
       PRINCIPLE 1 — UNIFORM INTERFACE
       ═══════════════════════════════════════════ -->
  <section id="principe-1" class="principle-section mb-24 scroll-mt-24">
    <div class="flex items-start gap-5 mb-8">
      <span class="principle-number shrink-0 w-14 h-14 flex items-center justify-center rounded-2xl bg-[var(--color-bg-code)] text-[var(--color-accent-ochre)] text-2xl font-light" style="font-family: var(--font-display); font-variation-settings: 'opsz' 144;">1</span>
      <div>
        <h2 class="mb-1" style="font-variation-settings: 'opsz' 72;">Uniform Interface</h2>
        <p class="text-[var(--color-text-secondary)] text-sm">Eén set regels voor alle resources</p>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 items-start">
      <div>
        <p class="mb-4 leading-relaxed">
          Alle resources op de server worden op <strong>dezelfde manier</strong> aangesproken.
          Je gebruikt standaard HTTP-methoden (GET, POST, PUT, DELETE) en consistente
          URL-structuren. Elke resource heeft één duidelijke URL en je weet meteen wat
          elke HTTP-methode doet.
        </p>
        <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed">
          Een ontwikkelaar die weet hoe <code class="text-sm px-1.5 py-0.5 rounded bg-[var(--color-bg-secondary)]">/games</code> werkt,
          weet automatisch hoe <code class="text-sm px-1.5 py-0.5 rounded bg-[var(--color-bg-secondary)]">/developers</code> werkt.
        </p>
      </div>

      <!-- Visual: consistent endpoint patterns -->
      <div class="bg-[var(--color-bg-code)] rounded-xl p-6 overflow-hidden" role="img" aria-label="Drie resources met dezelfde URL-structuur">
        <p class="text-[10px] uppercase tracking-widest text-[#6B6560] mb-5" style="font-family: var(--font-code);">Zelfde patroon, elke resource</p>
        <div class="space-y-4">
          {[
            { resource: 'games', color: 'var(--color-accent-ochre)' },
            { resource: 'developers', color: 'var(--color-accent-sage)' },
            { resource: 'reviews', color: 'var(--color-accent-rust)' },
          ].map(({ resource, color }) => (
            <div class="space-y-1.5">
              <div class="flex items-center gap-2">
                <span class="w-2 h-2 rounded-full shrink-0" style={`background: ${color};`}></span>
                <span class="text-xs font-medium" style={`font-family: var(--font-code); color: ${color};`}>/{resource}</span>
              </div>
              <div class="pl-4 grid grid-cols-2 gap-1.5 text-[11px]" style="font-family: var(--font-code);">
                <span class="text-[#A89F94]"><span class="text-[var(--color-accent-sage)]">GET</span> /{resource}</span>
                <span class="text-[#6B6560]">→ alle {resource}</span>
                <span class="text-[#A89F94]"><span class="text-[var(--color-accent-sage)]">GET</span> /{resource}/:id</span>
                <span class="text-[#6B6560]">→ één {resource === 'games' ? 'game' : resource === 'developers' ? 'developer' : 'review'}</span>
                <span class="text-[#A89F94]"><span class="text-[var(--color-accent-ochre)]">POST</span> /{resource}</span>
                <span class="text-[#6B6560]">→ nieuw aanmaken</span>
                <span class="text-[#A89F94]"><span class="text-[var(--color-accent-rust)]">DELETE</span> /{resource}/:id</span>
                <span class="text-[#6B6560]">→ verwijderen</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Key takeaway -->
    <div class="mt-8 pl-5 border-l-2 border-[var(--color-accent-ochre)]">
      <p class="text-sm text-[var(--color-text-secondary)]">
        <strong class="text-[var(--color-text-primary)]">Kernregel:</strong> Als je het patroon voor één resource kent, ken je het voor allemaal.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PRINCIPLE 2 — CLIENT-SERVER
       ═══════════════════════════════════════════ -->
  <section id="principe-2" class="principle-section mb-24 scroll-mt-24">
    <div class="flex items-start gap-5 mb-8">
      <span class="principle-number shrink-0 w-14 h-14 flex items-center justify-center rounded-2xl bg-[var(--color-bg-code)] text-[var(--color-accent-ochre)] text-2xl font-light" style="font-family: var(--font-display); font-variation-settings: 'opsz' 144;">2</span>
      <div>
        <h2 class="mb-1" style="font-variation-settings: 'opsz' 72;">Client-Server</h2>
        <p class="text-[var(--color-text-secondary)] text-sm">Strikte scheiding van verantwoordelijkheden</p>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 items-start">
      <div>
        <p class="mb-4 leading-relaxed">
          De <strong>client</strong> (browser, app, script) en de <strong>server</strong> (API)
          zijn volledig onafhankelijk van elkaar. De server levert alleen ruwe data. De client
          bepaalt hoe die data wordt getoond.
        </p>
        <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed">
          Hierdoor kan je de frontend volledig vervangen (bijv. van website naar mobiele app)
          zonder de API aan te passen, en andersom.
        </p>
      </div>

      <!-- Visual: client-server separation -->
      <div class="relative" role="img" aria-label="Client en server gescheiden met data-uitwisseling">
        <svg viewBox="0 0 440 220" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
          <!-- Client box -->
          <rect x="10" y="30" width="150" height="160" rx="12" fill="#EDE8E1" stroke="#D6D0C8" stroke-width="1.5"/>
          <text x="85" y="22" text-anchor="middle" fill="#6B6560" font-size="10" font-family="var(--font-code)" letter-spacing="0.05em">CLIENT</text>

          <!-- Client internals -->
          <rect x="28" y="58" width="114" height="24" rx="4" fill="#F7F3EE" stroke="#D6D0C8" stroke-width="1"/>
          <text x="85" y="74" text-anchor="middle" fill="#2D2A26" font-size="10" font-family="var(--font-body)">UI / Presentatie</text>

          <rect x="28" y="92" width="114" height="24" rx="4" fill="#F7F3EE" stroke="#D6D0C8" stroke-width="1"/>
          <text x="85" y="108" text-anchor="middle" fill="#2D2A26" font-size="10" font-family="var(--font-body)">Gebruikerslogica</text>

          <rect x="28" y="126" width="114" height="24" rx="4" fill="#F7F3EE" stroke="#D6D0C8" stroke-width="1"/>
          <text x="85" y="142" text-anchor="middle" fill="#2D2A26" font-size="10" font-family="var(--font-body)">HTTP Client</text>

          <text x="85" y="172" text-anchor="middle" fill="#6B6560" font-size="9" font-family="var(--font-body)">🖥️ Browser / App</text>

          <!-- Server box -->
          <rect x="280" y="30" width="150" height="160" rx="12" fill="#2D2A26" stroke="#2D2A26" stroke-width="1.5"/>
          <text x="355" y="22" text-anchor="middle" fill="#6B6560" font-size="10" font-family="var(--font-code)" letter-spacing="0.05em">SERVER</text>

          <!-- Server internals -->
          <rect x="298" y="58" width="114" height="24" rx="4" fill="#3D3A36" stroke="#4D4A46" stroke-width="1"/>
          <text x="355" y="74" text-anchor="middle" fill="#F7F3EE" font-size="10" font-family="var(--font-body)">Routes / Endpoints</text>

          <rect x="298" y="92" width="114" height="24" rx="4" fill="#3D3A36" stroke="#4D4A46" stroke-width="1"/>
          <text x="355" y="108" text-anchor="middle" fill="#F7F3EE" font-size="10" font-family="var(--font-body)">Businesslogica</text>

          <rect x="298" y="126" width="114" height="24" rx="4" fill="#3D3A36" stroke="#4D4A46" stroke-width="1"/>
          <text x="355" y="142" text-anchor="middle" fill="#F7F3EE" font-size="10" font-family="var(--font-body)">Database</text>

          <text x="355" y="172" text-anchor="middle" fill="#6B6560" font-size="9" font-family="var(--font-body)">⚙️ API Server</text>

          <!-- Arrows -->
          <line x1="168" y1="95" x2="272" y2="95" stroke="#D4A843" stroke-width="1.5" stroke-dasharray="6 3"/>
          <polygon points="272,95 264,90 264,100" fill="#D4A843"/>
          <text x="220" y="87" text-anchor="middle" fill="#D4A843" font-size="9" font-family="var(--font-code)">Request</text>

          <line x1="272" y1="130" x2="168" y2="130" stroke="#5B7B6A" stroke-width="1.5" stroke-dasharray="6 3"/>
          <polygon points="168,130 176,125 176,135" fill="#5B7B6A"/>
          <text x="220" y="148" text-anchor="middle" fill="#5B7B6A" font-size="9" font-family="var(--font-code)">JSON Response</text>

          <!-- Separation line -->
          <line x1="220" y1="30" x2="220" y2="190" stroke="#C4573A" stroke-width="1" stroke-dasharray="3 4" opacity="0.5"/>
          <text x="220" y="208" text-anchor="middle" fill="#C4573A" font-size="9" font-family="var(--font-code)" opacity="0.7">onafhankelijk</text>
        </svg>
      </div>
    </div>

    <div class="mt-8 pl-5 border-l-2 border-[var(--color-accent-ochre)]">
      <p class="text-sm text-[var(--color-text-secondary)]">
        <strong class="text-[var(--color-text-primary)]">Kernregel:</strong> De server weet niets over de UI. De client weet niets over de database. Ze communiceren alleen via HTTP.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PRINCIPLE 3 — STATELESS
       ═══════════════════════════════════════════ -->
  <section id="principe-3" class="principle-section mb-24 scroll-mt-24">
    <div class="flex items-start gap-5 mb-8">
      <span class="principle-number shrink-0 w-14 h-14 flex items-center justify-center rounded-2xl bg-[var(--color-bg-code)] text-[var(--color-accent-ochre)] text-2xl font-light" style="font-family: var(--font-display); font-variation-settings: 'opsz' 144;">3</span>
      <div>
        <h2 class="mb-1" style="font-variation-settings: 'opsz' 72;">Stateless</h2>
        <p class="text-[var(--color-text-secondary)] text-sm">Elke request staat op zichzelf</p>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 items-start">
      <div>
        <p class="mb-4 leading-relaxed">
          De server <strong>"vergeet" je na elk verzoek</strong>. De server bewaart geen informatie
          over voorgaande interacties. Elke aanvraag wordt als volledig nieuw behandeld en moet
          alle nodige informatie bevatten, inclusief authenticatie (zoals een JWT-token).
        </p>
        <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed">
          Waarom? Load balancers kunnen requests naar verschillende servers sturen,
          server crashes betekenen geen verloren sessies, en het is simpeler om te debuggen.
        </p>
      </div>

      <!-- Visual: three independent requests -->
      <div class="bg-[var(--color-bg-code)] rounded-xl p-6" role="img" aria-label="Drie onafhankelijke requests met eigen context">
        <p class="text-[10px] uppercase tracking-widest text-[#6B6560] mb-5" style="font-family: var(--font-code);">Elke request draagt eigen context</p>
        <div class="space-y-3">
          {[
            { time: '10:01', method: 'GET', path: '/games', desc: 'Lijst ophalen' },
            { time: '10:02', method: 'POST', path: '/games', desc: 'Game aanmaken' },
            { time: '10:03', method: 'GET', path: '/games/42', desc: 'Detail ophalen' },
          ].map(({ time, method, path, desc }, i) => (
            <div class="relative">
              <div class="flex items-stretch gap-3">
                <!-- Timestamp -->
                <span class="shrink-0 text-[10px] text-[#6B6560] pt-2.5 w-10 text-right" style="font-family: var(--font-code);">{time}</span>
                <!-- Request block -->
                <div class="flex-1 rounded-lg border border-[#3D3A36] p-3">
                  <div class="flex items-center gap-2 mb-2">
                    <span class={`text-[11px] font-medium ${method === 'POST' ? 'text-[var(--color-accent-ochre)]' : 'text-[var(--color-accent-sage)]'}`} style="font-family: var(--font-code);">{method}</span>
                    <span class="text-[11px] text-[#A89F94]" style="font-family: var(--font-code);">{path}</span>
                    <span class="ml-auto text-[10px] text-[#6B6560]">{desc}</span>
                  </div>
                  <!-- Token indicator -->
                  <div class="flex items-center gap-1.5">
                    <svg width="10" height="10" viewBox="0 0 10 10" class="shrink-0">
                      <rect x="0" y="0" width="10" height="10" rx="2" fill="#D4A843" opacity="0.2"/>
                      <path d="M5 2.5v5M3 5h4" stroke="#D4A843" stroke-width="1"/>
                    </svg>
                    <span class="text-[10px] text-[var(--color-accent-ochre)]" style="font-family: var(--font-code);">Authorization: Bearer eyJhbG...</span>
                  </div>
                </div>
              </div>
              {i < 2 && (
                <div class="ml-[52px] h-3 border-l border-dashed border-[#3D3A36]"></div>
              )}
            </div>
          ))}
        </div>
        <!-- No shared memory callout -->
        <div class="mt-5 flex items-center gap-2 text-[10px] text-[var(--color-accent-rust)]" style="font-family: var(--font-code);">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <circle cx="6" cy="6" r="5" stroke="currentColor" stroke-width="1"/>
            <path d="M4 4l4 4M8 4l-4 4" stroke="currentColor" stroke-width="1"/>
          </svg>
          Geen gedeelde sessie op de server
        </div>
      </div>
    </div>

    <div class="mt-8 pl-5 border-l-2 border-[var(--color-accent-ochre)]">
      <p class="text-sm text-[var(--color-text-secondary)]">
        <strong class="text-[var(--color-text-primary)]">Kernregel:</strong> Als je token verloopt, weet de server niet meer wie je bent. Hij wist het nooit.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PRINCIPLE 4 — CACHEABLE
       ═══════════════════════════════════════════ -->
  <section id="principe-4" class="principle-section mb-24 scroll-mt-24">
    <div class="flex items-start gap-5 mb-8">
      <span class="principle-number shrink-0 w-14 h-14 flex items-center justify-center rounded-2xl bg-[var(--color-bg-code)] text-[var(--color-accent-ochre)] text-2xl font-light" style="font-family: var(--font-display); font-variation-settings: 'opsz' 144;">4</span>
      <div>
        <h2 class="mb-1" style="font-variation-settings: 'opsz' 72;">Cacheable</h2>
        <p class="text-[var(--color-text-secondary)] text-sm">Slim hergebruik van responses</p>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 items-start">
      <div>
        <p class="mb-4 leading-relaxed">
          Een API kan bepaalde data <strong>tijdelijk opslaan</strong>
          (bijv. data die vaak wordt opgevraagd), zodat de client
          een stuk sneller antwoord krijgt. De API vertelt de client: "deze data mag
          je X tijd bewaren voordat je opnieuw moet vragen."
        </p>
        <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed">
          De header <code class="text-xs px-1.5 py-0.5 rounded bg-[var(--color-bg-secondary)]">Cache-Control</code> bepaalt het cachinggedrag:
          <code class="text-xs px-1.5 py-0.5 rounded bg-[var(--color-bg-secondary)]">max-age=300</code> voor 5 minuten caching,
          of <code class="text-xs px-1.5 py-0.5 rounded bg-[var(--color-bg-secondary)]">no-cache</code> voor live data die altijd vers moet zijn.
        </p>
      </div>

      <!-- Visual: cache flow -->
      <div class="relative" role="img" aria-label="Eerste request gaat naar server, tweede komt uit cache">
        <svg viewBox="0 0 440 280" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
          <!-- First request label -->
          <text x="220" y="16" text-anchor="middle" fill="#6B6560" font-size="10" font-family="var(--font-code)" letter-spacing="0.05em">EERSTE REQUEST</text>

          <!-- Client -->
          <rect x="20" y="32" width="100" height="44" rx="8" fill="#EDE8E1" stroke="#D6D0C8" stroke-width="1.5"/>
          <text x="70" y="58" text-anchor="middle" fill="#2D2A26" font-size="11" font-family="var(--font-body)">Client</text>

          <!-- Arrow to server -->
          <line x1="124" y1="54" x2="306" y2="54" stroke="#D4A843" stroke-width="1.5" stroke-dasharray="6 3"/>
          <polygon points="306,54 298,49 298,59" fill="#D4A843"/>
          <text x="215" y="46" text-anchor="middle" fill="#D4A843" font-size="8" font-family="var(--font-code)">GET /games</text>

          <!-- Server -->
          <rect x="310" y="32" width="110" height="44" rx="8" fill="#2D2A26"/>
          <text x="365" y="58" text-anchor="middle" fill="#F7F3EE" font-size="11" font-family="var(--font-body)">Server</text>

          <!-- Response back -->
          <line x1="306" y1="76" x2="124" y2="100" stroke="#5B7B6A" stroke-width="1.5" stroke-dasharray="6 3"/>
          <polygon points="124,100 133,97 131,107" fill="#5B7B6A"/>

          <!-- Cache-Control header -->
          <rect x="155" y="80" width="150" height="20" rx="4" fill="#5B7B6A" opacity="0.15"/>
          <text x="230" y="93" text-anchor="middle" fill="#5B7B6A" font-size="8" font-family="var(--font-code)">Cache-Control: max-age=300</text>

          <!-- Cache box -->
          <rect x="44" y="110" width="52" height="30" rx="6" fill="#D4A843" opacity="0.12" stroke="#D4A843" stroke-width="1" stroke-dasharray="3 2"/>
          <text x="70" y="129" text-anchor="middle" fill="#D4A843" font-size="8" font-family="var(--font-code)">Cache</text>

          <!-- Saved arrow -->
          <path d="M70 100 L70 110" stroke="#D4A843" stroke-width="1" stroke-dasharray="2 2"/>

          <!-- Divider -->
          <line x1="20" y1="160" x2="420" y2="160" stroke="#D6D0C8" stroke-width="0.5" stroke-dasharray="4 4"/>

          <!-- Second request label -->
          <text x="220" y="178" text-anchor="middle" fill="#6B6560" font-size="10" font-family="var(--font-code)" letter-spacing="0.05em">TWEEDE REQUEST (BINNEN 5 MIN)</text>

          <!-- Client 2 -->
          <rect x="20" y="192" width="100" height="44" rx="8" fill="#EDE8E1" stroke="#D6D0C8" stroke-width="1.5"/>
          <text x="70" y="218" text-anchor="middle" fill="#2D2A26" font-size="11" font-family="var(--font-body)">Client</text>

          <!-- Cache 2 -->
          <rect x="170" y="196" width="80" height="36" rx="8" fill="#D4A843" opacity="0.15" stroke="#D4A843" stroke-width="1.5"/>
          <text x="210" y="210" text-anchor="middle" fill="#D4A843" font-size="9" font-family="var(--font-code)">Cache</text>
          <text x="210" y="222" text-anchor="middle" fill="#D4A843" font-size="7" font-family="var(--font-code)">✓ geldig</text>

          <!-- Arrow to cache -->
          <line x1="124" y1="214" x2="166" y2="214" stroke="#D4A843" stroke-width="1.5"/>
          <polygon points="166,214 158,209 158,219" fill="#D4A843"/>

          <!-- Arrow back from cache -->
          <line x1="166" y1="220" x2="124" y2="220" stroke="#5B7B6A" stroke-width="1.5"/>
          <polygon points="124,220 132,215 132,225" fill="#5B7B6A"/>

          <!-- Grayed out server -->
          <rect x="310" y="192" width="110" height="44" rx="8" fill="#2D2A26" opacity="0.2"/>
          <text x="365" y="218" text-anchor="middle" fill="#6B6560" font-size="11" font-family="var(--font-body)">Server</text>

          <!-- X through server arrow -->
          <line x1="260" y1="214" x2="300" y2="214" stroke="#C4573A" stroke-width="1" opacity="0.4" stroke-dasharray="3 3"/>
          <text x="280" y="240" text-anchor="middle" fill="#C4573A" font-size="8" font-family="var(--font-code)" opacity="0.6">niet nodig</text>

          <!-- Speed label -->
          <text x="130" y="256" text-anchor="middle" fill="#5B7B6A" font-size="9" font-family="var(--font-code)">⚡ Instant response</text>
        </svg>
      </div>
    </div>

    <div class="mt-8 pl-5 border-l-2 border-[var(--color-accent-ochre)]">
      <p class="text-sm text-[var(--color-text-secondary)]">
        <strong class="text-[var(--color-text-primary)]">Kernregel:</strong> De server bepaalt de spelregels voor caching. De client (of een proxy) voert ze uit.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       PRINCIPLE 5 — LAYERED SYSTEM
       ═══════════════════════════════════════════ -->
  <section id="principe-5" class="principle-section mb-24 scroll-mt-24">
    <div class="flex items-start gap-5 mb-8">
      <span class="principle-number shrink-0 w-14 h-14 flex items-center justify-center rounded-2xl bg-[var(--color-bg-code)] text-[var(--color-accent-ochre)] text-2xl font-light" style="font-family: var(--font-display); font-variation-settings: 'opsz' 144;">5</span>
      <div>
        <h2 class="mb-1" style="font-variation-settings: 'opsz' 72;">Layered System</h2>
        <p class="text-[var(--color-text-secondary)] text-sm">Onzichtbare tussenlagen</p>
      </div>
    </div>

    <div class="grid lg:grid-cols-2 gap-10 items-start">
      <div>
        <p class="mb-4 leading-relaxed">
          De architectuur van de API kan opgedeeld worden in <strong>verschillende logische
          lagen</strong> met elk hun eigen verantwoordelijkheid. De client weet niet of hij
          rechtstreeks met de server praat of via tussenliggende systemen.
        </p>
        <p class="text-[var(--color-text-secondary)] text-sm leading-relaxed">
          Voordelen: beveiliging op meerdere niveaus, makkelijk schaalbaar (extra servers
          toevoegen), en onderhoudswerken zonder downtime.
        </p>
      </div>

      <!-- Visual: layered architecture -->
      <div class="relative" role="img" aria-label="Gelaagde architectuur met client, gateway, load balancer en servers">
        <svg viewBox="0 0 440 320" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full">
          <!-- Client -->
          <rect x="170" y="10" width="100" height="40" rx="8" fill="#EDE8E1" stroke="#D6D0C8" stroke-width="1.5"/>
          <text x="220" y="34" text-anchor="middle" fill="#2D2A26" font-size="11" font-family="var(--font-body)">Client</text>

          <!-- Arrow down -->
          <line x1="220" y1="50" x2="220" y2="72" stroke="#D6D0C8" stroke-width="1.5"/>
          <polygon points="220,72 215,64 225,64" fill="#D6D0C8"/>

          <!-- Layer 1: API Gateway -->
          <rect x="100" y="76" width="240" height="44" rx="10" fill="none" stroke="#C4573A" stroke-width="1.5" stroke-dasharray="5 3"/>
          <rect x="140" y="82" width="160" height="32" rx="6" fill="#C4573A" opacity="0.08"/>
          <text x="220" y="100" text-anchor="middle" fill="#C4573A" font-size="10" font-family="var(--font-body)" font-weight="500">API Gateway</text>
          <text x="220" y="112" text-anchor="middle" fill="#C4573A" font-size="7" font-family="var(--font-code)" opacity="0.7">auth · rate limiting · routing</text>

          <!-- Arrow down -->
          <line x1="220" y1="120" x2="220" y2="142" stroke="#D6D0C8" stroke-width="1.5"/>
          <polygon points="220,142 215,134 225,134" fill="#D6D0C8"/>

          <!-- Layer 2: Load Balancer -->
          <rect x="100" y="146" width="240" height="44" rx="10" fill="none" stroke="#D4A843" stroke-width="1.5" stroke-dasharray="5 3"/>
          <rect x="140" y="152" width="160" height="32" rx="6" fill="#D4A843" opacity="0.08"/>
          <text x="220" y="170" text-anchor="middle" fill="#D4A843" font-size="10" font-family="var(--font-body)" font-weight="500">Load Balancer</text>
          <text x="220" y="182" text-anchor="middle" fill="#D4A843" font-size="7" font-family="var(--font-code)" opacity="0.7">verdeelt verkeer over servers</text>

          <!-- Arrows branching -->
          <line x1="220" y1="190" x2="120" y2="224" stroke="#D6D0C8" stroke-width="1.5"/>
          <line x1="220" y1="190" x2="220" y2="224" stroke="#D6D0C8" stroke-width="1.5"/>
          <line x1="220" y1="190" x2="320" y2="224" stroke="#D6D0C8" stroke-width="1.5"/>

          <!-- Layer 3: Servers -->
          <rect x="70" y="228" width="100" height="40" rx="8" fill="#2D2A26"/>
          <text x="120" y="252" text-anchor="middle" fill="#F7F3EE" font-size="10" font-family="var(--font-body)">Server A</text>

          <rect x="170" y="228" width="100" height="40" rx="8" fill="#2D2A26"/>
          <text x="220" y="252" text-anchor="middle" fill="#F7F3EE" font-size="10" font-family="var(--font-body)">Server B</text>

          <rect x="270" y="228" width="100" height="40" rx="8" fill="#2D2A26"/>
          <text x="320" y="252" text-anchor="middle" fill="#F7F3EE" font-size="10" font-family="var(--font-body)">Server C</text>

          <!-- Database -->
          <line x1="120" y1="268" x2="220" y2="290" stroke="#D6D0C8" stroke-width="1"/>
          <line x1="220" y1="268" x2="220" y2="290" stroke="#D6D0C8" stroke-width="1"/>
          <line x1="320" y1="268" x2="220" y2="290" stroke="#D6D0C8" stroke-width="1"/>

          <ellipse cx="220" cy="300" rx="50" ry="12" fill="#5B7B6A" opacity="0.15" stroke="#5B7B6A" stroke-width="1"/>
          <text x="220" y="304" text-anchor="middle" fill="#5B7B6A" font-size="9" font-family="var(--font-code)">Database</text>

          <!-- Client's view bracket -->
          <line x1="22" y1="10" x2="22" y2="310" stroke="#C4573A" stroke-width="1" opacity="0.3"/>
