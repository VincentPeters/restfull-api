---
import '../styles/global.css';

interface Props {
  title: string;
  breadcrumbs?: { label: string; href?: string }[];
}

const { title, breadcrumbs } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL;

const exerciseLinks = [
  { label: 'REST Quiz', href: `${base}/oefeningen/rest-quiz` },
  { label: 'Architectuur', href: `${base}/oefeningen/architectuur` },
  { label: 'URI Spotter', href: `${base}/oefeningen/uri-spotter` },
  { label: 'URI Builder', href: `${base}/oefeningen/uri-builder` },
  { label: 'JSON Explorer', href: `${base}/oefeningen/json-explorer` },
];
const isExercisePage = currentPath.includes('/oefeningen/');
---

<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="Interactief compendium bij de RESTful API cursus – KdG" />
    <title>{title} – RESTful API Compendium</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navigation -->
    <nav class="border-b border-[var(--color-border)] bg-[var(--color-bg-primary)] sticky top-0 z-10">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-baseline justify-between gap-6">
        <a href={base} class="no-underline shrink-0">
          <span class="text-xl font-normal tracking-tight text-[var(--color-text-primary)] hover:text-[var(--color-accent-rust)]" style="font-family: var(--font-display); font-variation-settings: 'opsz' 144;">
            RESTful API Compendium
          </span>
        </a>
        <!-- Desktop nav -->
        <div class="hidden lg:flex items-center gap-6 text-sm">
          <a
            href={`${base}/naslagwerk`}
            class:list={[
              'transition-colors duration-200 whitespace-nowrap',
              currentPath.includes('/naslagwerk')
                ? 'text-[var(--color-accent-rust)] font-medium'
                : 'text-[var(--color-text-secondary)] hover:text-[var(--color-accent-rust)]',
            ]}
          >
            Naslagwerk
          </a>
          <a
            href={`${base}/principes`}
            class:list={[
              'transition-colors duration-200 whitespace-nowrap',
              currentPath.includes('/principes')
                ? 'text-[var(--color-accent-rust)] font-medium'
                : 'text-[var(--color-text-secondary)] hover:text-[var(--color-accent-rust)]',
            ]}
          >
            REST-principes
          </a>
          <a
            href={`${base}/uri-naamgeving`}
            class:list={[
              'transition-colors duration-200 whitespace-nowrap',
              currentPath.includes('/uri-naamgeving')
                ? 'text-[var(--color-accent-rust)] font-medium'
                : 'text-[var(--color-text-secondary)] hover:text-[var(--color-accent-rust)]',
            ]}
          >
            URI-naamgeving
          </a>
          <a
            href={`${base}/api-clients`}
            class:list={[
              'transition-colors duration-200 whitespace-nowrap',
              currentPath.includes('/api-clients')
                ? 'text-[var(--color-accent-rust)] font-medium'
                : 'text-[var(--color-text-secondary)] hover:text-[var(--color-accent-rust)]',
            ]}
          >
            API Clients
          </a>
          <!-- Exercises dropdown -->
          <div class="relative" id="exercises-dropdown">
            <button
              type="button"
              class:list={[
                'flex items-center gap-1 transition-colors duration-200 whitespace-nowrap cursor-pointer',
                isExercisePage
                  ? 'text-[var(--color-accent-rust)] font-medium'
                  : 'text-[var(--color-text-secondary)] hover:text-[var(--color-accent-rust)]',
              ]}
            >
              Oefeningen
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" class="mt-px transition-transform duration-200" id="dropdown-chevron">
                <path d="M3 5l3 3 3-3" />
              </svg>
            </button>
            <div id="exercises-menu" class="hidden absolute top-full left-0 mt-2 py-2 min-w-[180px] bg-[var(--color-bg-primary)] border border-[var(--color-border)] rounded-lg shadow-lg">
              {exerciseLinks.map((link) => (
                <a
                  href={link.href}
                  class:list={[
                    'block px-4 py-2 text-sm transition-colors duration-200',
                    currentPath.startsWith(link.href)
                      ? 'text-[var(--color-accent-rust)] font-medium bg-[var(--color-bg-secondary)]'
                      : 'text-[var(--color-text-secondary)] hover:text-[var(--color-accent-rust)] hover:bg-[var(--color-bg-secondary)]',
                  ]}
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
          <a href="https://kdg-gaming-api.me-945.workers.dev/docs" target="_blank" rel="noopener" class="text-[var(--color-text-secondary)] hover:text-[var(--color-accent-rust)] transition-colors duration-200 whitespace-nowrap">
            Gaming API ↗
          </a>
          <button type="button" class="beamer-toggle" id="beamer-toggle-desktop" aria-label="Beamer mode toggle">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" />
              <line x1="8" y1="21" x2="16" y2="21" />
              <line x1="12" y1="17" x2="12" y2="21" />
            </svg>
          </button>
        </div>
        <!-- Mobile hamburger -->
        <button id="mobile-menu-btn" class="lg:hidden text-[var(--color-text-secondary)] hover:text-[var(--color-text-primary)] cursor-pointer" aria-label="Menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M4 7h16M4 12h16M4 17h16" />
          </svg>
        </button>
      </div>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden lg:hidden border-t border-[var(--color-border)] bg-[var(--color-bg-primary)]">
        <div class="max-w-5xl mx-auto px-6 py-3 flex flex-col gap-2">
          <a
            href={`${base}/naslagwerk`}
            class:list={[
              'py-2 text-sm transition-colors duration-200',
              currentPath.includes('/naslagwerk')
                ? 'text-[var(--color-accent-rust)] font-medium'
                : 'text-[var(--color-text-secondary)] hover:text-[var(--color-accent-rust)]',
            ]}
          >
            Naslagwerk
          </a>
          <a
            href={`${base}/principes`}
            class:list={[
              'py-2 text-sm transition-colors duration-200',
              currentPath.includes('/principes')
                ? 'text-[var(--color-accent-rust)] font-medium'
                : 'text-[var(--color-text-secondary)] hover:text-[var(--color-accent-rust)]',
            ]}
          >
            REST-principes
          </a>
          <a
            href={`${base}/uri-naamgeving`}
            class:list={[
              'py-2 text-sm transition-colors duration-200',
              currentPath.includes('/uri-naamgeving')
                ? 'text-[var(--color-accent-rust)] font-medium'
                : 'text-[var(--color-text-secondary)] hover:text-[var(--color-accent-rust)]',
            ]}
          >
            URI-naamgeving
          </a>
          <a
            href={`${base}/api-clients`}
            class:list={[
              'py-2 text-sm transition-colors duration-200',
              currentPath.includes('/api-clients')
                ? 'text-[var(--color-accent-rust)] font-medium'
                : 'text-[var(--color-text-secondary)] hover:text-[var(--color-accent-rust)]',
            ]}
          >
            API Clients
          </a>
          <span class="pt-2 pb-1 text-xs font-medium text-[var(--color-text-secondary)] uppercase tracking-wider">Oefeningen</span>
          {exerciseLinks.map((link) => (
            <a
              href={link.href}
              class:list={[
                'py-2 pl-3 text-sm transition-colors duration-200',
                currentPath.startsWith(link.href)
                  ? 'text-[var(--color-accent-rust)] font-medium'
                  : 'text-[var(--color-text-secondary)] hover:text-[var(--color-accent-rust)]',
              ]}
            >
              {link.label}
            </a>
          ))}
          <a href="https://kdg-gaming-api.me-945.workers.dev/docs" target="_blank" rel="noopener" class="py-2 text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-accent-rust)] transition-colors duration-200">
            Gaming API ↗
          </a>
          <button type="button" class="beamer-toggle mt-2" id="beamer-toggle-mobile" aria-label="Beamer mode toggle">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="3" width="20" height="14" rx="2" />
              <line x1="8" y1="21" x2="16" y2="21" />
              <line x1="12" y1="17" x2="12" y2="21" />
            </svg>
          </button>
        </div>
      </div>
    </nav>

    <!-- Breadcrumbs -->
    {breadcrumbs && breadcrumbs.length > 0 && (
      <div class="max-w-5xl mx-auto px-6 pt-4">
        <div class="flex gap-2 text-xs text-[var(--color-text-secondary)]">
          <a href={base} class="hover:text-[var(--color-accent-rust)] transition-colors">Home</a>
          {breadcrumbs.map((crumb) => (
            <>
              <span>/</span>
              {crumb.href ? (
                <a href={crumb.href} class="hover:text-[var(--color-accent-rust)] transition-colors">{crumb.label}</a>
              ) : (
                <span class="text-[var(--color-text-primary)]">{crumb.label}</span>
              )}
            </>
          ))}
        </div>
      </div>
    )}

    <!-- Main Content -->
    <main class="flex-1 max-w-5xl mx-auto px-6 py-10 w-full">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-[var(--color-border)] mt-auto">
      <div class="max-w-5xl mx-auto px-6 py-6 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-[var(--color-text-secondary)]">
        <span>
          Gemaakt voor KdG door
          <a href="https://vinnie.studio" target="_blank" rel="noopener" class="hover:text-[var(--color-accent-rust)] transition-colors">
            Studio Vinnie
          </a>
        </span>
        <a href="https://kdg-gaming-api.me-945.workers.dev/docs" target="_blank" rel="noopener" class="hover:text-[var(--color-accent-rust)] transition-colors">
          Gaming API Docs ↗
        </a>
      </div>
    </footer>

    <script>
      // Beamer mode — apply early to prevent flash
      (function() {
        const urlParams = new URLSearchParams(window.location.search);
        const urlBeamer = urlParams.get('beamer');
        if (urlBeamer === '1') {
          document.documentElement.classList.add('beamer-mode');
          localStorage.setItem('beamer-mode', 'on');
        } else if (urlBeamer === '0') {
          document.documentElement.classList.remove('beamer-mode');
          localStorage.setItem('beamer-mode', 'off');
        } else if (localStorage.getItem('beamer-mode') === 'on') {
          document.documentElement.classList.add('beamer-mode');
        }
      })();

      // Mobile menu toggle
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));

      // Exercises dropdown
      const dropdown = document.getElementById('exercises-dropdown');
      const dropdownMenu = document.getElementById('exercises-menu');
      const chevron = document.getElementById('dropdown-chevron');

      dropdown?.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !dropdownMenu?.classList.contains('hidden');
        dropdownMenu?.classList.toggle('hidden');
        chevron?.classList.toggle('rotate-180', !isOpen);
      });

      document.addEventListener('click', () => {
        dropdownMenu?.classList.add('hidden');
        chevron?.classList.remove('rotate-180');
      });

      // Beamer mode toggle
      function toggleBeamer() {
        const isOn = document.documentElement.classList.toggle('beamer-mode');
        localStorage.setItem('beamer-mode', isOn ? 'on' : 'off');
      }

      document.getElementById('beamer-toggle-desktop')?.addEventListener('click', toggleBeamer);
      document.getElementById('beamer-toggle-mobile')?.addEventListener('click', toggleBeamer);
    </script>
  </body>
</html>
